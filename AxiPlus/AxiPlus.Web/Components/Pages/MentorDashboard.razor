    private static bool TryParseDate(string value, out DateTime result)
   {
        return DateTime.TryParse(value, out result);
    }

    private List<DayOfWeek> GetSelectedWeeklyDays()
   {
        var days = new List<DayOfWeek>();

        if (weeklyMonday)
       {
            days.Add(DayOfWeek.Monday);
        }

        if (weeklyTuesday)
       {
            days.Add(DayOfWeek.Tuesday);
        }

        if (weeklyWednesday)
       {
            days.Add(DayOfWeek.Wednesday);
        }

        if (weeklyThursday)
       {
            days.Add(DayOfWeek.Thursday);
        }

        if (weeklyFriday)
       {
            days.Add(DayOfWeek.Friday);
        }

        return days;
    }

    private static string GetRoleLabel(string role)
   {
        return role switch
       {
            "AssistantMentor" => "Assistant Mentor",
            "MainMentor" => "Main Mentor",
            _ => role
        };
    }

    private static Color GetAttendanceColor(decimal value)
   {
        if (value >= 85)
       {
            return Color.Success;
        }

        return value >= 70 ? Color.Warning : Color.Error;
    }

    private static Color GetSubmissionColor(AssignmentSubmissionStatus status)
   {
        return status switch
       {
            AssignmentSubmissionStatus.Reviewed => Color.Success,
            AssignmentSubmissionStatus.RevisionRequested => Color.Warning,
            AssignmentSubmissionStatus.Submitted => Color.Info,
            _ => Color.Default
        };
    }

    private static Color GetSupportColor(SupportTicketStatus status)
   {
        return status switch
       {
            SupportTicketStatus.Resolved => Color.Success,
            SupportTicketStatus.InReview => Color.Info,
            _ => Color.Warning
        };
    }

    private static Color GetMeetingColor(MeetingRequestStatus status)
   {
        return status switch
       {
            MeetingRequestStatus.Accepted => Color.Success,
            MeetingRequestStatus.Completed => Color.Success,
            MeetingRequestStatus.Called => Color.Warning,
            MeetingRequestStatus.Rejected => Color.Error,
            _ => Color.Info
        };
    }

    private static Color GetDiscrepancyColor(AttendanceDiscrepancyStatus status)
   {
        return status switch
       {
            AttendanceDiscrepancyStatus.Approved => Color.Success,
            AttendanceDiscrepancyStatus.Rejected => Color.Error,
            AttendanceDiscrepancyStatus.InReview => Color.Info,
            _ => Color.Warning
        };
    }
