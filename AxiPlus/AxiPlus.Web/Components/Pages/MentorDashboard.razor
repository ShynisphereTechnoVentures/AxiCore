    private async Task CreateWeeklySessionsAsync()
   {
        var days = GetSelectedWeeklyDays();

        if (weeklyBatchId == Guid.Empty ||
            string.IsNullOrWhiteSpace(weeklyMeetLink) ||
            !DateTime.TryParse(weeklyStartDate, out var weekStart) ||
            !TimeSpan.TryParse(weeklyStartTime, out var startTime) ||
            !TimeSpan.TryParse(weeklyEndTime, out var endTime) ||
            days.Count == 0 ||
            endTime <= startTime)
       {
            ShowStatus("Batch, week start, link, valid time, and at least one day are required.", Severity.Error);
            return;
        }

        isSaving = true;

        var created = await MentorService.CreateWeeklySessionsAsync(
            new CreateMentorWeeklySessionsModel
           {
                BatchId = weeklyBatchId,
                WeekStartDate = weekStart.Date,
                TitlePrefix = "Live Class",
                MeetLink = weeklyMeetLink,
                StartTime = startTime,
                EndTime = endTime,
                Days = days
            });

        isSaving = false;

        if (created.Count == 0)
       {
            ShowStatus("Weekly live links could not be uploaded.", Severity.Error);
            return;
        }

        sessions = await MentorService.GetSessionsAsync();
        dashboard = await MentorService.GetDashboardAsync();
        ShowStatus($"{created.Count} weekly live links uploaded.", Severity.Success);
    }

