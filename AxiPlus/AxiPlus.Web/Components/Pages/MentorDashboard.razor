    private async Task SaveAttendanceAsync()
   {
        if (attendanceRoster == null)
       {
            return;
        }

        var records = attendanceRoster.Students
            .Where(x => x.Status.HasValue)
            .Select(x => new MarkMentorAttendanceEntryModel
           {
                StudentId = x.StudentId,
                Status = x.Status!.Value
            })
            .ToList();

        isSaving = true;

        var updated = await MentorService.MarkAttendanceAsync(
            attendanceRoster.SessionId,
            new MarkMentorAttendanceModel{ Records = records });

        isSaving = false;

        if (updated == null)
       {
            ShowStatus("Attendance could not be saved.", Severity.Error);
            return;
        }

        attendanceRoster = updated;
        sessions = await MentorService.GetSessionsAsync();
        students = await MentorService.GetStudentsAsync();
        batches = await MentorService.GetBatchesAsync();
        ShowStatus("Attendance saved.", Severity.Success);
    }

    private void SetRosterStatus(AttendanceStatus status)
   {
        if (attendanceRoster == null)
       {
            return;
        }

        foreach (var entry in attendanceRoster.Students)
       {
            entry.Status = status;
        }
    }

    private void SetUnmarkedAbsent()
   {
        if (attendanceRoster == null)
       {
            return;
        }

        foreach (var entry in attendanceRoster.Students.Where(x => !x.Status.HasValue))
       {
            entry.Status = AttendanceStatus.Absent;
        }
    }

