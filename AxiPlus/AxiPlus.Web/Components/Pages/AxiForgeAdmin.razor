    private async Task ExportContentAsync()
    {
        Console.WriteLine("Entering -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ExportContentAsync");
        try
        {
            var bundle = await AdminService.ExportAxiForgeContentAsync();
            importExportJson = JsonSerializer.Serialize(bundle, new JsonSerializerOptions { WriteIndented = true });
            Snackbar.Add("AxiForge JSON exported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ExportContentAsync -> {ex.Message}");
            Snackbar.Add("Export failed.", Severity.Error);
        }
        finally
        {
            Console.WriteLine("Exiting -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ExportContentAsync");
        }
    }

    private async Task ImportContentAsync()
    {
        Console.WriteLine("Entering -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ImportContentAsync");
        try
        {
            isSaving = true;
            var bundle = JsonSerializer.Deserialize<AxiForgeAdminImportExportModel>(
                importExportJson,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (bundle == null)
            {
                Snackbar.Add("Import JSON is not valid.", Severity.Error);
                return;
            }

            var imported = await AdminService.ImportAxiForgeContentAsync(bundle);
            Snackbar.Add(imported ? "AxiForge content imported." : "Import failed.", imported ? Severity.Success : Severity.Error);
            if (imported)
            {
                await LoadAsync();
            }
        }
        catch (JsonException ex)
        {
            Console.WriteLine($"Exception -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ImportContentAsync -> {ex.Message}");
            Snackbar.Add("Import JSON is not valid.", Severity.Error);
        }
        finally
        {
            isSaving = false;
            Console.WriteLine("Exiting -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> ImportContentAsync");
        }
    }

    private async Task RunMutationAsync(Func<Task<bool>> action, string successMessage, string errorMessage)
    {
        Console.WriteLine("Entering -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> RunMutationAsync");
        try
        {
            isSaving = true;
            var completed = await action();
            Snackbar.Add(completed ? successMessage : errorMessage, completed ? Severity.Success : Severity.Error);
            if (completed)
            {
                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> RunMutationAsync -> {ex.Message}");
            Snackbar.Add(errorMessage, Severity.Error);
        }
        finally
        {
            isSaving = false;
            Console.WriteLine("Exiting -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> RunMutationAsync");
        }
    }

    private void AddProblemTestCase() => problemForm.TestCases.Add(new SaveAxiForgeTestCaseModel { Order = problemForm.TestCases.Count + 1 });
    private void AddRoadmapStep() => roadmapForm.Steps.Add(new SaveAxiForgeRoadmapStepModel { Order = roadmapForm.Steps.Count + 1 });
    private void AddAssessmentQuestion() => assessmentForm.Questions.Add(new SaveAxiForgeQuestionModel { Order = assessmentForm.Questions.Count + 1 });
    private void InsertProblemBold() => InsertProblemToken("**bold**");
    private void InsertProblemCode() => InsertProblemToken("`code`");
    private void InsertProblemList() => InsertProblemToken("<ul><li>point</li></ul>");

    private void InsertProblemToken(string token)
    {
        problemForm.Description = string.IsNullOrWhiteSpace(problemForm.Description)
            ? token
            : $"{problemForm.Description}{Environment.NewLine}{token}";
    }

    private bool ValidateProblemForm()
    {
        if (string.IsNullOrWhiteSpace(problemForm.Title) ||
            string.IsNullOrWhiteSpace(problemForm.Topic) ||
            string.IsNullOrWhiteSpace(problemForm.Description))
        {
            Snackbar.Add("Problem title, topic, and statement are required.", Severity.Error);
            return false;
        }

        if (problemForm.TestCases.Count == 0 ||
            problemForm.TestCases.Any(x => string.IsNullOrWhiteSpace(x.ExpectedOutput)))
        {
            Snackbar.Add("At least one test case with expected output is required.", Severity.Error);
            return false;
        }

        return true;
    }

    private void EditProblem(AxiForgeAdminProblemModel problem)
    {
        problemForm = new SaveAxiForgeProblemModel
        {
            Id = problem.Id,
            Slug = problem.Slug,
            Title = problem.Title,
            Description = problem.Description,
            InputFormat = problem.InputFormat,
            OutputFormat = problem.OutputFormat,
            Constraints = problem.Constraints,
            Examples = problem.Examples,
            Explanation = problem.Explanation,
            Difficulty = problem.Difficulty,
            Topic = problem.Topic,
            Tags = problem.Tags,
            ClassTags = problem.ClassTags,
            CompanyTags = problem.CompanyTags,
            StarterCode = problem.StarterCode,
            StarterCodeByLanguage = problem.StarterCodeByLanguage,
            ExpectedOutput = problem.ExpectedOutput,
            TimeLimitMilliseconds = problem.TimeLimitMilliseconds,
            MemoryLimitKb = problem.MemoryLimitKb,
            IsPublished = problem.IsPublished,
            ApprovalStatus = problem.ApprovalStatus,
            TestCases = problem.TestCases.Select(x => new SaveAxiForgeTestCaseModel
            {
                Input = x.Input,
                ExpectedOutput = x.ExpectedOutput,
                IsHidden = x.IsHidden,
                Order = x.Order
            }).ToList()
        };
    }

