    private async Task LoadAsync()
    {
        Console.WriteLine("Entering -> AxiPlus.Web -> Components/Pages -> AxiForgeAdmin.razor -> LoadAsync");
        try
        {
            isLoading = true;
            problems = await AdminService.GetAxiForgeProblemsAsync();
            roadmaps = await AdminService.GetAxiForgeRoadmapsAsync();
            assessments = await AdminService.GetAxiForgeAssessmentsAsync();
            lessons = await AdminService.GetAxiForgeLessonsAsync();
            lessonMappings = await AdminService.GetAxiForgeLessonMappingsAsync();
            auditEntries = await AdminService.GetAxiForgeAuditAsync();
            taxonomyItems = await AdminService.GetAxiForgeTaxonomyAsync();
