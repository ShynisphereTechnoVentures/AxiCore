@page "/reset-password"
@layout AxiPlus.Web.Components.Layout.AuthLayout

<div class="auth-card">
    <div class="auth-card-title">
        <MudText Typo="Typo.h4">Reset password</MudText>
        <MudText Typo="Typo.body2" Class="muted-text">
            Account recovery
        </MudText>
    </div>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        Password reset is not enabled yet.
    </MudAlert>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth="true"
               Href="/login">
        Back to Login
    </MudButton>
</div>
