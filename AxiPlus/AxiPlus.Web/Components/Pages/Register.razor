@page "/register"
@rendermode InteractiveServer
@layout AxiPlus.Web.Components.Layout.AuthLayout

@using System.Net.Http.Json
@using AxiPlus.Application.DTOs.Students

@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Student Registration</PageTitle>

<div class="auth-card">
    <div class="auth-card-title">
        <MudText Typo="Typo.h4">Create account</MudText>
        <MudText Typo="Typo.body2" Class="muted-text">
            Student registration
        </MudText>
    </div>

    <MudTextField T="string"
                  Label="Full name"
                  Variant="Variant.Outlined"
                  @bind-Value="model.FullName"
                  Class="mb-3" />

    <MudTextField T="string"
                  Label="Email"
                  Variant="Variant.Outlined"
                  @bind-Value="model.Email"
                  Class="mb-3" />

    <MudTextField T="string"
                  Label="Phone number"
                  Variant="Variant.Outlined"
                  @bind-Value="model.PhoneNumber"
                  Class="mb-3" />

    <MudTextField T="string"
                  Label="Password"
                  Variant="Variant.Outlined"
                  InputType="InputType.Password"
                  @bind-Value="model.Password"
                  Class="mb-4" />

    @if (!string.IsNullOrEmpty(message))
   {
        <MudAlert Severity="@messageSeverity" Dense="true" Class="mb-4">
            @message
        </MudAlert>
    }

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth="true"
               Disabled="@isSubmitting"
               OnClick="RegisterStudent">
        Register
    </MudButton>

    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
        <MudLink Href="/login">Back to login</MudLink>
    </MudStack>
</div>

@code{
    private RegisterStudentDto model = new();
    private string message = string.Empty;
    private Severity messageSeverity = Severity.Info;
    private bool isSubmitting;

    private async Task RegisterStudent()
   {
        message = string.Empty;

        if (string.IsNullOrWhiteSpace(model.FullName) ||
            string.IsNullOrWhiteSpace(model.Email) ||
            string.IsNullOrWhiteSpace(model.Password))
       {
            messageSeverity = Severity.Warning;
            message = "Full name, email, and password are required.";
            return;
        }

        isSubmitting = true;

        var response = await Http.PostAsJsonAsync(
            "/api/students/register",
            model);

        isSubmitting = false;

        if (response.IsSuccessStatusCode)
       {
            messageSeverity = Severity.Success;
            message = "Registration successful.";

            await Task.Delay(1200);

            Navigation.NavigateTo("/login");
        }
        else
       {
            messageSeverity = Severity.Error;
            message = await response.Content.ReadAsStringAsync();
        }
    }
}
